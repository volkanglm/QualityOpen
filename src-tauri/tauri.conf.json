{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QualityOpen",
  "version": "1.0.9",
  "identifier": "com.ivg.qualityopen",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QualityOpen",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "center": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; worker-src blob:; style-src 'self' 'unsafe-inline' blob:; img-src 'self' data: blob: https:; media-src 'self' blob: data:; font-src 'self' data:; connect-src 'self' https://*.googleapis.com wss://*.googleapis.com; frame-src 'none'; object-src 'none'; base-uri 'none';"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlFMEU4MzQyMTVFNEYzMkMKUldRczgrUVZRb01PbnA0OStoUzhlcFlSekxOeXNXVm9HKy9iQWEwUFcwSmdZK1NFVTQ4a0QyNlQK",
      "endpoints": [
        "https://raw.githubusercontent.com/volkanglm/QualityOpen/main/updater.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist"
    }
  }
}